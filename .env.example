# Zona horaria de la app (Monterrey). Usar el mismo valor en ambas vars.
APP_TIMEZONE="America/Monterrey"
NEXT_PUBLIC_APP_TIMEZONE="America/Monterrey"

# URL de PostgreSQL. Local: contenedor Docker del docker-compose.yml.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://wick:wick@localhost:5433/wick?schema=public"
# Conexión directa (sin pooler) — solo la usa `prisma migrate deploy`.
# Local: igual que DATABASE_URL. Vercel Postgres: copia el valor de
# POSTGRES_URL_NON_POOLING tal cual (postgresql://...), NO el nombre de la var.
DIRECT_URL="postgresql://wick:wick@localhost:5433/wick?schema=public"

# URL pública de la app (NextAuth la usa para callbacks). Local:
NEXTAUTH_URL="http://localhost:3000"

# Secreto de NextAuth — generar con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Usuario admin inicial (bootstrap). Se crea en DB al primer login si no existe.
# Ya no se usa para auth en runtime — solo para seed del primer ADMIN.
ADMIN_EMAIL=""

# Hash bcrypt de la password del admin, codificado en base64 (sin `$`).
# Generar con: npm run hash-password  (devuelve el base64 listo para pegar).
# El base64 evita que dotenv-expand corrompa los `$2b$10$...` del hash bcrypt.
ADMIN_PASSWORD_HASH=""

# 2FA TOTP opcional: secret base32 de 6 dígitos / 30s (RFC 6238).
# Generar con: npm run totp:setup  (devuelve el secret + la URI otpauth).
# Si se deja vacío, el login sólo requiere email+password. Si se setea, el
# form de login pide además un código desde tu app autenticadora.
ADMIN_TOTP_SECRET=""

# Solo para deploy en Vercel: token del Blob store (ver DEPLOY.md, paso 5).
# Local no se usa — el adaptador de storage escribe a ./uploads/ en disco.
# En Vercel no hay disco persistente, así que hay que migrar a Vercel Blob.
BLOB_READ_WRITE_TOKEN=""
