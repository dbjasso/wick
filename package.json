{
  "name": "wick",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env -u DATABASE_URL -u DIRECT_URL -u ADMIN_EMAIL -u ADMIN_PASSWORD_HASH -u ADMIN_TOTP_SECRET next dev",
    "build": "next build",
    "vercel-build": "sh scripts/vercel-build.sh",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "db:push": "env -u DATABASE_URL -u DIRECT_URL -u ADMIN_EMAIL -u ADMIN_PASSWORD_HASH -u ADMIN_TOTP_SECRET prisma db push",
    "db:studio": "env -u DATABASE_URL -u DIRECT_URL -u ADMIN_EMAIL -u ADMIN_PASSWORD_HASH -u ADMIN_TOTP_SECRET prisma studio",
    "db:migrate": "env -u DATABASE_URL -u DIRECT_URL -u ADMIN_EMAIL -u ADMIN_PASSWORD_HASH -u ADMIN_TOTP_SECRET prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "hash-password": "tsx scripts/hash-password.ts",
    "totp:setup": "tsx scripts/totp-secret.ts",
    "postinstall": "prisma generate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mobile": "playwright test --project=Mobile",
    "test:e2e:desktop": "playwright test --project=Desktop"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
